---
import { getCollection } from 'astro:content';
import Hero from '@astrojs/starlight/components/Hero.astro';

const docs = await getCollection('docs');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anjalikastra — Autonomous web testing agent</title>
  </head>
  <body>
    <main>
      <section class="hero">
        <h1>🕸️ Anjalikastra</h1>
        <p class="tagline">Point it at a URL. Get a runnable test suite.</p>
        <p class="description">
          Autonomous web testing agent that crawls a live website black-box and generates a runnable Playwright E2E suite plus an honest coverage report.
        </p>
        <div class="actions">
          <a href="/docs/getting-started/" class="btn btn-primary">Get Started</a>
          <a href="/docs/" class="btn">Read Docs</a>
        </div>
      </section>

      <section class="features">
        <h2>Features</h2>
        <div class="grid">
          <div class="feature">
            <h3>Black-box crawling</h3>
            <p>Discovers pages and endpoints from the live site alone — no repo or CI access.</p>
          </div>
          <div class="feature">
            <h3>Runnable suite</h3>
            <p>TypeScript + Playwright Test files that install and run with one command.</p>
          </div>
          <div class="feature">
            <h3>Honest coverage</h3>
            <p>Reports state what was tested and why pages weren't reached.</p>
          </div>
          <div class="feature">
            <h3>Any LLM</h3>
            <p>Claude, OpenAI, Ollama, OpenRouter, Gemini, or heuristic fallback.</p>
          </div>
          <div class="feature">
            <h3>Cheap reruns</h3>
            <p>Content-hash caching means second runs cost almost nothing.</p>
          </div>
          <div class="feature">
            <h3>Human in the loop</h3>
            <p>Bugs are drafted, never auto-filed.</p>
          </div>
        </div>
      </section>
    </main>

    <style is:global>
      :root {
        --accent: #14b8a6;
        --text: #0f172a;
        --bg: #ffffff;
        --border: #e2e8f0;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --text: #f1f5f9;
          --bg: #0f172a;
          --border: #334155;
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }

      .hero {
        text-align: center;
        padding: 3rem 0;
      }

      .hero h1 {
        font-size: 3.5rem;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, var(--accent), #00d4aa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .tagline {
        font-size: 1.75rem;
        margin-bottom: 1rem;
        opacity: 0.7;
      }

      .description {
        max-width: 50rem;
        margin: 1.5rem auto 2.5rem;
        font-size: 1.1rem;
        opacity: 0.8;
      }

      .actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin: 2rem 0;
      }

      .btn {
        padding: 0.875rem 1.75rem;
        border-radius: 0.5rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
        border: 2px solid;
        display: inline-block;
      }

      .btn-primary {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }

      .btn-primary:hover {
        opacity: 0.9;
        transform: translateY(-2px);
      }

      .btn {
        border-color: var(--accent);
        color: var(--accent);
      }

      .btn:hover {
        background: var(--accent);
        color: white;
      }

      .features {
        margin-top: 5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
      }

      .features h2 {
        text-align: center;
        margin-bottom: 3rem;
        font-size: 2rem;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
      }

      .feature h3 {
        color: var(--accent);
        margin-bottom: 0.5rem;
      }

      .feature p {
        opacity: 0.7;
      }
    </style>
  </body>
</html>
